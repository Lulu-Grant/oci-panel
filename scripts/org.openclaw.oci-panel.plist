<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.openclaw.oci-panel</string>

  <key>WorkingDirectory</key>
  <string>/Users/apple/.openclaw/workspace/oci-panel</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/apple/.openclaw/workspace/oci-panel/scripts/start-oci-panel.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>/Users/apple/.openclaw/workspace/oci-panel/.runtime/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/apple/.openclaw/workspace/oci-panel/.runtime/launchd.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>NODE_ENV</key>
    <string>production</string>
    <key>HOSTNAME</key>
    <string>0.0.0.0</string>
    <key>PORT</key>
    <string>3000</string>
  </dict>
</dict>
</plist>
